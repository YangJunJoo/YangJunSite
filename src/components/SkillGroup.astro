---
import type { SkillGroup } from '../utils/content';

interface Props {
  skillGroup: SkillGroup;
  isDetailed?: boolean;
}

const { skillGroup, isDetailed = false } = Astro.props;
---

<div class="p-6 md:p-8 bg-white border border-slate-200/80 rounded-xl">
  <h3 class="text-lg font-bold text-slate-900 border-b border-slate-100 pb-3 mb-4 flex items-center justify-between">
    {skillGroup.group}
    <span class="text-xs font-semibold text-indigo-650 bg-indigo-50 border border-indigo-100/60 px-2 py-0.5 rounded">
      {skillGroup.items.length} Skills
    </span>
  </h3>

  {isDetailed ? (
    <div class="space-y-4">
      {skillGroup.items.map((item) => (
        <div class="group">
          <h4 class="text-sm font-bold text-slate-800 group-hover:text-indigo-600 transition-colors">
            {item.name}
          </h4>
          <p class="text-xs text-slate-500 mt-1 leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  ) : (
    <div class="flex flex-wrap gap-2">
      {skillGroup.items.map((item) => (
        <span class="text-xs font-semibold text-slate-700 bg-slate-50 border border-slate-200/80 px-3 py-1.5 rounded-lg select-none hover:bg-slate-100 transition-colors">
          {item.name}
        </span>
      ))}
    </div>
  )}
</div>

---
import Layout from '../components/Layout.astro';
import Section from '../components/Section.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getPublications } from '../utils/content';

const publicationGroups = getPublications();
---

<Layout 
  title="Publications | Yang-Jun Joo, Ph.D." 
  description="Selected peer-reviewed publications and conference proceedings by Dr. Yang-Jun Joo in top-tier transportation safety, AI, and computer vision venues."
>
  <Section 
    title="Selected Publications" 
    subtitle="A curated archive of peer-reviewed articles and manuscripts. Rather than a purely academic list, this catalog highlights the industrial translation and applied value of each research contribution."
  >
    <div class="space-y-16 mt-8">
      {publicationGroups.map((group) => (
        <div class="space-y-6">
          <h3 class="text-lg font-bold text-indigo-750 border-b border-indigo-100 pb-2 mb-6 flex items-center gap-2 select-none">
            <span class="h-1.5 w-1.5 rounded-full bg-indigo-600"></span>
            {group.group}
          </h3>
          <div class="grid grid-cols-1 gap-6">
            {group.items.map((pub) => (
              <PublicationCard publication={pub} />
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>
</Layout>

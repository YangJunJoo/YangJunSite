---
import { getExperience } from '../utils/content';
const experience = getExperience();

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
const roles = limit ? experience.roles.slice(0, limit) : experience.roles;

const getAdvisorLink = (advisorName: string) => {
  const name = advisorName.toLowerCase();
  if (name.includes('abdel-aty') || name.includes('aty')) {
    return 'https://scholar.google.com/citations?user=dG5K3sAAAAAJ';
  }
  if (name.includes('dong-kyu') || name.includes('dongkyu') || name.includes('동규')) {
    return 'https://scholar.google.com/citations?user=IZmrE08AAAAJ';
  }
  return null;
};
---

<div class="space-y-12">
  <!-- Work History Timeline -->
  <div class="relative border-l border-slate-200 ml-3 pl-8 space-y-12">
    {roles.map((role) => (
      <div class="relative group">
        <!-- Dot -->
        <span class="absolute -left-[41px] top-1.5 flex h-6 w-6 items-center justify-center rounded-full bg-white border-2 border-indigo-600 shadow-sm group-hover:scale-110 transition-transform">
          <span class="h-2 w-2 rounded-full bg-indigo-600" />
        </span>
        
        <div class="space-y-2">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 text-slate-500">
            <span class="text-xs font-bold tracking-wider text-indigo-700 uppercase bg-indigo-50 border border-indigo-100/60 px-2 py-0.5 rounded w-fit select-none">
              {role.period}
            </span>
            {role.advisor && (
              <span class="text-xs font-semibold">
                Advisor:{' '}
                {getAdvisorLink(role.advisor) ? (
                  <a href={getAdvisorLink(role.advisor)} target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-850 hover:underline transition-colors font-bold">
                    {role.advisor}
                  </a>
                ) : (
                  <span class="text-slate-700">{role.advisor}</span>
                )}
              </span>
            )}
          </div>
          
          <h3 class="text-lg font-bold text-slate-900 leading-tight">
            {role.role}
          </h3>
          
          <p class="text-sm font-semibold text-slate-600">
            {role.institution}
          </p>
          
          <ul class="mt-4 list-disc pl-4 space-y-2 text-sm text-slate-500 leading-relaxed font-normal">
            {role.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>

  {!limit && (
    <div class="pt-8 border-t border-slate-200/60">
      <h3 class="text-xl font-bold text-slate-950 mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l-9-5.25M12 14v7.5M12 21.5l-9-5.25" />
        </svg>
        Education
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {experience.education.map((edu) => (
          <div class="p-5 bg-white border border-slate-200/80 rounded-xl">
            <h4 class="text-sm font-bold text-slate-900">{edu.degree}</h4>
            <p class="text-xs text-slate-500 mt-1.5 font-medium">{edu.institution}</p>
          </div>
        ))}
      </div>
    </div>
  )}
</div>

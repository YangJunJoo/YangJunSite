---
interface Props {
  title: string;
  subtitle?: string;
  className?: string;
  id?: string;
}

const { title, subtitle, className = '', id } = Astro.props;
---

<section id={id} class={`py-16 md:py-24 border-b border-slate-100 last:border-b-0 ${className}`}>
  <div class="mx-auto max-w-4xl px-6">
    <div class="mb-12">
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-slate-900">
        {title}
      </h2>
      {subtitle && (
        <p class="mt-2 text-base text-slate-500 max-w-2xl">
          {subtitle}
        </p>
      )}
      <div class="mt-4 h-1 w-12 rounded bg-indigo-600"></div>
    </div>
    <slot />
  </div>
</section>

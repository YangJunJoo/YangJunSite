---
import { getProfile } from '../utils/content';
const profile = getProfile();
const pathname = new URL(Astro.request.url).pathname;

const isActive = (path: string) => {
  if (path === '/' && pathname === '/') return true;
  if (path !== '/' && pathname.startsWith(path)) return true;
  return false;
};

const navItems = [
  { name: 'Home', path: '/' },
  { name: 'Projects', path: '/projects' },
  { name: 'Publications', path: '/publications' },
  { name: 'Skills', path: '/skills' },
  { name: 'Experience', path: '/experience' },
  { name: 'Contact', path: '/contact' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200/80 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="flex flex-col select-none group">
      <span class="text-lg font-bold tracking-tight text-slate-900 group-hover:text-indigo-600 transition-colors">{profile.name}</span>
      <span class="text-xs text-slate-500 font-medium hidden sm:inline">Applied Researcher · Autonomous Driving & Mobility AI</span>
    </a>
    
    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-1">
      {navItems.map((item) => (
        <a
          href={item.path}
          class={`px-4 py-2 text-sm font-medium rounded-lg transition-all duration-150 ${
            isActive(item.path)
              ? 'bg-slate-100/80 text-indigo-700 font-semibold'
              : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'
          }`}
        >
          {item.name}
        </a>
      ))}
    </nav>

    <!-- Mobile Navigation Toggle -->
    <div class="flex items-center md:hidden">
      <button id="mobile-menu-btn" class="p-2 text-slate-600 hover:text-slate-900 focus:outline-none" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="hidden border-b border-slate-200 bg-white md:hidden animate-fade-in">
    <nav class="flex flex-col space-y-1 px-6 py-4">
      {navItems.map((item) => (
        <a
          href={item.path}
          class={`px-3 py-2.5 text-base font-medium rounded-lg transition-colors ${
            isActive(item.path)
              ? 'bg-slate-100 text-indigo-700 font-semibold'
              : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
          }`}
        >
          {item.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
